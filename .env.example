# =========================================================================
# CROESE ANTHONIUS - SHOPIFY PREMIUM THEME HUB - CONFIG EXAMPLE
# =========================================================================

# Paddle Client Token recovery from Paddle Developer Tools Menu (Paddle Billing v2)
VITE_PADDLE_CLIENT_TOKEN=

# Paddle Mode. Allowed values: "sandbox" or "production"
VITE_PADDLE_ENVIRONMENT=sandbox

# Deployed domain URL address for target canonicals
VITE_SITE_URL=

# =========================================================================
# THEME PADDLE PAYMENTS PRICE IDs
# =========================================================================

# Gravity Premium Theme SKU
VITE_PADDLE_PRICE_ID_GRAVITY=

# Lively Premium Theme SKU
VITE_PADDLE_PRICE_ID_LIVELY=

# Soleway Retail Theme SKU
VITE_PADDLE_PRICE_ID_SOLEWAY=

# Vows Luxury Theme SKU
VITE_PADDLE_PRICE_ID_VOWS=

# Crimson Fashion Theme SKU
VITE_PADDLE_PRICE_ID_CRIMSON=
