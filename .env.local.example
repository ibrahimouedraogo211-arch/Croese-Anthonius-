# =========================================================================
# EXPERT CONFIGURATION DE BASE - BOUTIQUE DE THÈMES SHOPIFY & PADDLE
# =========================================================================

# Token Public Client de l'application Paddle Billing (v2)
# Récupérable sur votre Dashboard commercial Paddle -> Developer Tools -> Client Tokens
VITE_PADDLE_CLIENT_TOKEN=your_paddle_client_token

# Choix de l'environnement Paddle. Valeurs possibles : "sandbox" ou "production"
# Nous conseillons d'activer "sandbox" pendant toute la phase de validation technique de vos thèmes.
VITE_PADDLE_ENVIRONMENT=sandbox

# Adresse principale de production de votre boutique de thèmes
# Ex : https://votre-boutique-themes.vercel.app
VITE_SITE_URL=your_deployed_site_url

# =========================================================================
# LES IDENTIFIANTS DE PAIEMENTS PADDLE BILLING (PRICE IDs)
# À créer sur votre Dashboard Paddle -> Catalog -> Products -> Prices.
# Note : Ces IDs commencent en général par "pri_..."
# =========================================================================

# Thème 1 : Gravity (Haute densité & grands catalogues de vêtements, Prix conseillé : 590$)
VITE_PADDLE_PRICE_ID_GRAVITY=pri_01jk98yrt3v2abc1234567890e

# Thème 2 : Lively (Canaux physiques & secteur alimentaire, Prix conseillé : 680$)
VITE_PADDLE_PRICE_ID_LIVELY=pri_01jk98yrt3v2abc4567890123f

# Thème 3 : Soleway (Omicaux physique-digital & vente détail réelle, Prix conseillé : 880$)
VITE_PADDLE_PRICE_ID_SOLEWAY=pri_01jk98yrt3v2abc7890123456g

# Thème 4 : Vows (Flexibilité extrême de blocs & Luxe, Prix conseillé : 320$)
VITE_PADDLE_PRICE_ID_VOWS=pri_01jk98yrt3v2abc8901234567h

# Thème 5 : Crimson (Mode & Passion boutique, Prix conseillé : 520$)
VITE_PADDLE_PRICE_ID_CRIMSON=pri_01jk98yrt3v2abc8901234567i
